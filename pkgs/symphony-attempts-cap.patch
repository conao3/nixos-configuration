diff --git a/lib/symphony_elixir/orchestrator.ex b/lib/symphony_elixir/orchestrator.ex
index 0445776..d359c82 100644
--- a/lib/symphony_elixir/orchestrator.ex
+++ b/lib/symphony_elixir/orchestrator.ex
@@ -924,13 +924,43 @@ defmodule SymphonyElixir.Orchestrator do
   end
 
   defp spawn_issue_on_worker_host(%State{} = state, issue, attempt, recipient, worker_host) do
+    max_attempts = Config.settings!().agent.max_attempts_per_issue
+    final_attempt = is_integer(max_attempts) and max_attempts > 0 and is_integer(attempt) and attempt >= max_attempts
+    cap_exceeded = is_integer(max_attempts) and max_attempts > 0 and is_integer(attempt) and attempt > max_attempts
+
+    if cap_exceeded do
+      force_cancel_attempt_limit(state, issue, attempt, max_attempts)
+    else
+      spawn_issue_on_worker_host_impl(state, issue, attempt, recipient, worker_host, final_attempt)
+    end
+  end
+
+  defp force_cancel_attempt_limit(%State{} = state, issue, attempt, max_attempts) do
+    Logger.warning("CanceledByAttemptLimit: #{issue_context(issue)} attempt=#{attempt} > max_attempts_per_issue=#{max_attempts}; forcing Cancelled without spawn")
+
+    case Tracker.update_issue_state(issue.id, "Cancelled") do
+      :ok ->
+        :ok
+
+      {:error, reason} ->
+        Logger.error("CanceledByAttemptLimit: Tracker.update_issue_state failed for #{issue_context(issue)}: #{inspect(reason)}")
+    end
+
+    %{
+      state
+      | retry_attempts: Map.delete(state.retry_attempts, issue.id),
+        claimed: MapSet.delete(state.claimed, issue.id)
+    }
+  end
+
+  defp spawn_issue_on_worker_host_impl(%State{} = state, issue, attempt, recipient, worker_host, final_attempt) do
     case Task.Supervisor.start_child(SymphonyElixir.TaskSupervisor, fn ->
-           AgentRunner.run(issue, recipient, attempt: attempt, worker_host: worker_host)
+           AgentRunner.run(issue, recipient, attempt: attempt, final_attempt: final_attempt, worker_host: worker_host)
          end) do
       {:ok, pid} ->
         ref = Process.monitor(pid)
 
-        Logger.info("Dispatching issue to agent: #{issue_context(issue)} pid=#{inspect(pid)} attempt=#{inspect(attempt)} worker_host=#{worker_host || "local"}")
+        Logger.info("Dispatching issue to agent: #{issue_context(issue)} pid=#{inspect(pid)} attempt=#{inspect(attempt)} final_attempt=#{final_attempt} worker_host=#{worker_host || "local"}")
 
         running =
           Map.put(state.running, issue.id, %{
